generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CompanyStatus {
  ACTIVE
  SUSPENDED
}

enum Role {
  SUPERADMIN
  OWNER
  SITE_MANAGER
  SUPERVISOR
  WORKER
  EMPLOYEE
}

enum SiteStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum WalletTxnType {
  TOPUP
  EXPENSE
  TRANSFER_OUT
  TRANSFER_IN
  VENDOR_PAYMENT
  REVERSAL
  SALARY
  ADVANCE_RECOVERY
}

enum Direction {
  CREDIT
  DEBIT
}

enum ExpenseCategory {
  MATERIALS
  LABOR
  TRANSPORT
  FOOD
  MISC
  OTHER
}

enum IncomeType {
  ADVANCE
  RUNNING_BILL
  FINAL
  RETENTION
}

enum AttendanceStatus {
  PRESENT
  HALF_DAY
  ABSENT
}

enum AttendanceMethod {
  SELFIE
  MANUAL
}

enum OwnershipType {
  OWNED
  RENTED
}

enum AssetStatus {
  AVAILABLE
  MAINTENANCE
  DECOMMISSIONED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Company {
  id          String        @id @default(cuid())
  name        String        @unique
  ownerMobile String?       @unique
  status      CompanyStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  users               User[]
  sites               Site[]
  vendors             Vendor[]
  walletTransactions  WalletTransaction[]
  purchases           Purchase[]
  materialTransfers   MaterialTransfer[]
  siteIncomes         SiteIncome[]
  siteAssignments     SiteAssignment[]
  attendances         Attendance[]
  siteUpdates         SiteUpdate[]
  materialConsumptions MaterialConsumption[]
  assetCategories     AssetCategory[]
  assets              Asset[]
  assetAllocations    AssetAllocation[]
  payrollNotes        PayrollNote[]
}

model User {
  id                    String    @id @default(cuid())
  companyId             String?
  company               Company?  @relation(fields: [companyId], references: [id])
  username              String
  passwordHash          String
  name                  String
  role                  Role
  title                 String?
  mobileNumber          String?
  mobileVerified        Boolean   @default(false)
  joinedAt              DateTime  @default(now())
  isActive              Boolean   @default(true)
  lastLoginAt           DateTime?
  onboardingDismissedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  walletTransactionsAsActor        WalletTransaction[] @relation("ActorTransactions")
  walletTransactionsAsLogger       WalletTransaction[] @relation("LoggedTransactions")
  walletTransactionsAsCounterparty WalletTransaction[] @relation("CounterpartyTransactions")
  walletTransactionsAsVoider       WalletTransaction[] @relation("VoidedTransactions")
  purchasesAsPayer                 Purchase[]          @relation("PayerPurchases")
  purchasesAsLogger                Purchase[]          @relation("LoggedPurchases")
  purchasesAsVoider                Purchase[]          @relation("VoidedPurchases")
  transfersAsLogger                MaterialTransfer[]  @relation("LoggedTransfers")
  transfersAsVoider                MaterialTransfer[]  @relation("VoidedTransfers")
  siteIncomesAsLogger              SiteIncome[]        @relation("LoggedIncomes")
  siteIncomesAsVoider              SiteIncome[]        @relation("VoidedIncomes")
  siteAssignments                  SiteAssignment[]
  attendancesAsUser                Attendance[]        @relation("AttendanceUser")
  attendancesAsMarker              Attendance[]        @relation("AttendanceMarkedBy")
  submittedUpdates                 SiteUpdate[]        @relation("SubmittedUpdates")
  voidedUpdates                    SiteUpdate[]        @relation("VoidedUpdates")
  loggedConsumptions               MaterialConsumption[] @relation("LoggedConsumptions")
  voidedConsumptions               MaterialConsumption[] @relation("VoidedConsumptions")
  loggedAllocations                AssetAllocation[]     @relation("LoggedAllocations")
  voidedAllocations                AssetAllocation[]     @relation("VoidedAllocations")
  payrollNotesAsSubject            PayrollNote[]         @relation("PayrollNoteSubject")
  payrollNotesAsCreator            PayrollNote[]         @relation("PayrollNoteCreator")

  @@unique([companyId, username])
  @@index([companyId])
}

model Site {
  id                 String     @id @default(cuid())
  companyId          String
  company            Company    @relation(fields: [companyId], references: [id])
  name               String
  location           String
  clientName         String
  contractValuePaise BigInt
  startDate          DateTime
  expectedEndDate    DateTime?
  status             SiteStatus @default(ACTIVE)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  walletTransactions   WalletTransaction[]
  purchases            Purchase[]            @relation("DestinationPurchases")
  transfersIn          MaterialTransfer[]    @relation("ToTransfers")
  transfersOut         MaterialTransfer[]    @relation("FromTransfers")
  incomes              SiteIncome[]
  siteAssignments      SiteAssignment[]
  attendances          Attendance[]
  siteUpdates          SiteUpdate[]
  materialConsumptions MaterialConsumption[]
  assetAllocations     AssetAllocation[]

  @@index([companyId])
}

model Vendor {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  name         String
  contactPhone String?
  gstin        String?
  address      String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchases Purchase[]

  @@index([companyId])
}

model WalletTransaction {
  id                 String          @id @default(cuid())
  companyId          String
  company            Company         @relation(fields: [companyId], references: [id])
  actorUserId        String
  actor              User            @relation("ActorTransactions", fields: [actorUserId], references: [id])
  loggedById         String
  loggedBy           User            @relation("LoggedTransactions", fields: [loggedById], references: [id])
  type               WalletTxnType
  direction          Direction
  amountPaise        BigInt
  siteId             String?
  site               Site?           @relation(fields: [siteId], references: [id])
  counterpartyUserId String?
  counterparty       User?           @relation("CounterpartyTransactions", fields: [counterpartyUserId], references: [id])
  category           ExpenseCategory?
  note               String?
  paymentDate        DateTime? @db.Date
  billPhotoUrl       String?
  billPhotoPublicId  String?
  relatedPurchaseId  String?
  relatedTransferId  String?
  voidedAt           DateTime?
  voidedById         String?
  voidedBy           User?           @relation("VoidedTransactions", fields: [voidedById], references: [id])
  createdAt          DateTime        @default(now())

  @@index([actorUserId])
  @@index([siteId])
  @@index([createdAt])
  @@index([companyId])
}

model Purchase {
  id                String   @id @default(cuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  vendorId          String
  vendor            Vendor   @relation(fields: [vendorId], references: [id])
  itemName          String
  quantity          Decimal  @db.Decimal(14, 4)
  unit              String
  ratePaise         BigInt
  discountPercent   Decimal  @default(0) @db.Decimal(5, 2)
  gstPercent        Decimal  @default(0) @db.Decimal(5, 2)
  totalPaise        BigInt
  destinationSiteId String?
  destinationSite   Site?    @relation("DestinationPurchases", fields: [destinationSiteId], references: [id])
  paidByUserId      String?
  paidBy            User?    @relation("PayerPurchases", fields: [paidByUserId], references: [id])
  purchaseDate      DateTime
  billPhotoUrl      String?
  billPhotoPublicId String?
  note              String?
  loggedById        String
  loggedBy          User     @relation("LoggedPurchases", fields: [loggedById], references: [id])
  voidedAt          DateTime?
  voidedById        String?
  voidedBy          User?    @relation("VoidedPurchases", fields: [voidedById], references: [id])
  createdAt         DateTime @default(now())

  @@index([destinationSiteId])
  @@index([vendorId])
  @@index([companyId])
}

model MaterialTransfer {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  fromSiteId     String?
  fromSite       Site?    @relation("FromTransfers", fields: [fromSiteId], references: [id])
  toSiteId       String
  toSite         Site     @relation("ToTransfers", fields: [toSiteId], references: [id])
  itemName       String
  quantity       Decimal  @db.Decimal(14, 4)
  unit           String
  costMovedPaise BigInt
  transferDate   DateTime
  note           String?
  loggedById     String
  loggedBy       User     @relation("LoggedTransfers", fields: [loggedById], references: [id])
  voidedAt       DateTime?
  voidedById     String?
  voidedBy       User?    @relation("VoidedTransfers", fields: [voidedById], references: [id])
  createdAt      DateTime @default(now())

  @@index([fromSiteId])
  @@index([toSiteId])
  @@index([companyId])
}

model SiteIncome {
  id           String     @id @default(cuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  siteId       String
  site         Site       @relation(fields: [siteId], references: [id])
  amountPaise  BigInt
  receivedDate DateTime
  type         IncomeType
  note         String?
  loggedById   String
  loggedBy     User       @relation("LoggedIncomes", fields: [loggedById], references: [id])
  voidedAt     DateTime?
  voidedById   String?
  voidedBy     User?      @relation("VoidedIncomes", fields: [voidedById], references: [id])
  createdAt    DateTime   @default(now())

  @@index([siteId, receivedDate])
  @@index([companyId])
}

model SiteAssignment {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, siteId])
  @@index([companyId])
  @@index([userId])
  @@index([siteId])
}

model Attendance {
  id               String           @id @default(cuid())
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id])
  userId           String
  user             User             @relation("AttendanceUser", fields: [userId], references: [id])
  markedById       String
  markedBy         User             @relation("AttendanceMarkedBy", fields: [markedById], references: [id])
  date             DateTime         @db.Date
  status           AttendanceStatus
  method           AttendanceMethod
  photoUrl         String?
  photoPublicId    String?
  latitude         Float?
  longitude        Float?
  locationAccuracy Float?
  siteId           String?
  site             Site?            @relation(fields: [siteId], references: [id])
  createdAt        DateTime         @default(now())

  @@unique([companyId, userId, date])
  @@index([companyId, date])
  @@index([userId])
}

model SiteUpdate {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  siteId        String
  site          Site      @relation(fields: [siteId], references: [id])
  workDone      String
  headcount     Int?
  blockers      String?
  photos        Json      @default("[]")
  submittedById String
  submittedBy   User      @relation("SubmittedUpdates", fields: [submittedById], references: [id])
  editedAt      DateTime?
  voidedAt      DateTime?
  voidedById    String?
  voidedBy      User?     @relation("VoidedUpdates", fields: [voidedById], references: [id])
  createdAt     DateTime  @default(now())

  @@index([companyId, siteId, createdAt])
  @@index([siteId, createdAt])
}

model MaterialConsumption {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  siteId       String
  site         Site     @relation(fields: [siteId], references: [id])
  itemName     String
  quantity     Decimal  @db.Decimal(14, 4)
  unit         String
  consumedDate DateTime
  note         String?
  loggedById   String
  loggedBy     User     @relation("LoggedConsumptions", fields: [loggedById], references: [id])
  voidedAt     DateTime?
  voidedById   String?
  voidedBy     User?    @relation("VoidedConsumptions", fields: [voidedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([companyId, siteId, createdAt])
  @@index([siteId])
}

model AssetCategory {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets    Asset[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Asset {
  id                    String        @id @default(cuid())
  companyId             String
  company               Company       @relation(fields: [companyId], references: [id])
  categoryId            String
  category              AssetCategory @relation(fields: [categoryId], references: [id])
  name                  String
  ownershipType         OwnershipType
  defaultDailyCostPaise BigInt?
  status                AssetStatus   @default(AVAILABLE)
  notes                 String?
  photoUrl              String?
  photoPublicId         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  allocations AssetAllocation[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([categoryId])
}

model AssetAllocation {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id])
  assetId           String
  asset             Asset     @relation(fields: [assetId], references: [id])
  siteId            String?
  site              Site?     @relation(fields: [siteId], references: [id])
  startDate         DateTime  @db.Date
  endDate           DateTime? @db.Date
  dailyCostPaise    BigInt?
  includeInSiteCost Boolean   @default(true)
  notes             String?
  loggedById        String
  loggedBy          User      @relation("LoggedAllocations", fields: [loggedById], references: [id])
  voidedAt          DateTime?
  voidedById        String?
  voidedBy          User?     @relation("VoidedAllocations", fields: [voidedById], references: [id])
  createdAt         DateTime  @default(now())

  @@index([companyId])
  @@index([assetId, endDate])
  @@index([siteId])
  @@index([startDate])
}

model PayrollNote {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  userId      String
  user        User     @relation("PayrollNoteSubject", fields: [userId], references: [id])
  note        String
  noteDate    DateTime @db.Date
  createdById String
  createdBy   User     @relation("PayrollNoteCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([companyId, userId])
}
