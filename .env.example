# ─── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL direct connection string (used by Prisma for migrations)
# Get this from your Neon project dashboard → Connection Details → Direct
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ─── Session ──────────────────────────────────────────────────────────────────
# 32+ character random string for signing encrypted session cookies
# Generate one with: openssl rand -base64 32
SESSION_SECRET=

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Server-side Cloudinary SDK credentials (never exposed to browser)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Client-side Cloudinary config (safe to expose — these are public)
# Must match the server-side values above
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# Optional: only set these if you want to use a named Cloudinary upload preset.
CLOUDINARY_UPLOAD_PRESET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
